{
  "version": "0.2.0",
  "configurations": [
    {
      "name": ".NET: BillSplitter API",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "backend: build",
      "program": "${workspaceFolder}/backend/src/BillSplitter.Api/bin/Debug/net10.0/BillSplitter.Api.dll",
      "cwd": "${workspaceFolder}/backend/src/BillSplitter.Api",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5205"
      },
      "console": "integratedTerminal"
    },
    {
      "name": "Web: Vite dev server",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm dev",
      "cwd": "${workspaceFolder}/frontend",
      "env": { "VITE_API_BASE_URL": "http://localhost:5205" }
    }
  ],
  "compounds": [
    {
      "name": "Full stack (API + web)",
      "configurations": [".NET: BillSplitter API", "Web: Vite dev server"],
      "stopAll": true
    }
  ]
}
