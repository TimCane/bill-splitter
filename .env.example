# Secrets and per-deploy values for docker-compose.prod.yml. Static config
# (images, ports, internal hostnames, session tuning) lives in the compose file
# and appsettings.json - override those only with reason (docs/13-deployment.md).

# Public origin the browser reaches, used to build short-code join URLs.
APP_PUBLIC_BASE_URL=https://split.example.com

# MinIO credentials - the app authenticates with these root keys.
# Generate: openssl rand -hex 20
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# Email (optional): leave unset to disable the summary email. With no host the
# finalize dialog hides its address field.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@split.example.com

# CIDR of the network the reverse proxy sits on, trusted for X-Forwarded-For.
# The compose default (172.16.0.0/12) covers the Docker bridge; narrow it if the
# proxy has a fixed address.
TRUSTED_PROXY_NETWORK=172.16.0.0/12

# --- One-time / server-side setup (not docker-compose) -----------------------
# 1. Copy this file to .env and fill the blanks (MINIO_ROOT_USER/PASSWORD).
# 2. Point the TLS reverse proxy at 127.0.0.1:8080, forwarding the WebSocket
#    upgrade and X-Forwarded-For, and do not log query strings
#    (docs/13-deployment.md, added by the deploy step).
